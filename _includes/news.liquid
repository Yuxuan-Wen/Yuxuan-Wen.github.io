<div class="news">
  {% if site.news != blank %}
    {% assign news_size = site.news | size %}
    <div
      class="table-responsive"
      {% if include.limit and page.announcements.scrollable and news_size > 3 %}
        style="max-height: 60vw"
      {% endif %}
    >
      <table class="table table-sm table-borderless">
        {% assign news = site.news | reverse %}
        {% if include.limit and page.announcements.limit %}
          {% assign news_limit = page.announcements.limit %}
        {% else %}
          {% assign news_limit = news_size %}
        {% endif %}
        {% for item in news limit: news_limit %}
          {% comment %} LOCAL OVERRIDE of al_folio_core 1.0.11: show "Season Year" instead of "%b %d, %Y". {% endcomment %}
          {% assign _m = item.date | date: '%m' | plus: 0 %}
          {% assign _y = item.date | date: '%Y' %}
          {% if _m >= 3 and _m <= 5 %}
            {% assign _season = 'Spring' %}
          {% elsif _m >= 6 and _m <= 8 %}
            {% assign _season = 'Summer' %}
          {% elsif _m >= 9 and _m <= 11 %}
            {% assign _season = 'Fall' %}
          {% else %}
            {% assign _season = 'Winter' %}
          {% endif %}
          <tr>
            <th scope="row" style="width: 20%">{{ _season }} {{ _y }}</th>
            <td>
              {% if item.inline %}
                {{ item.content | remove: '<p>' | remove: '</p>' | emojify }}
              {% else %}
                <a class="news-title" href="{{ item.url | relative_url }}">{{ item.title }}</a>
              {% endif %}
            </td>
          </tr>
        {% endfor %}
      </table>
    </div>
  {% else %}
    <p>No news so far...</p>
  {% endif %}
</div>
